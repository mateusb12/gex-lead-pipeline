# Ambiente da aplicação.
#
# production:
# - modo padrão recomendado para validação;
# - exige SMS_WEBHOOK_URL configurada;
# - use quando quiser validar o POST real do SMS Worker no webhook.site.
#
# dev:
# - permite deixar SMS_WEBHOOK_URL vazia;
# - o worker de SMS tenta gerar uma URL dinâmica do webhook.site para facilitar testes locais.
APP_ENV=production

# Gere uma URL nova em https://webhook.site e cole aqui para validar o distribuidor SMS.
SMS_WEBHOOK_URL=

# Chave do gateway grummer.
# Se vazio, o projeto tenta ler assets/grummer_secret.txt.
GRUMMER_SECRET_HEX=
